# ============================================
# AI-OT Environment Configuration
# GitHub + Supabase deployment
# ============================================

# Supabase (Required)
SUPABASE_URL=https://cbsmjeaxrcgrxiplytll.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_anon_key_here

# ============================================
# AI Providers (At least one required)
# ============================================

# Groq - Fastest, 1M tokens/day free
# Get key: https://console.groq.com
GROQ_API_KEY=your_groq_api_key

# DeepSeek - Good Russian language support
# Get key: https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key

# OpenRouter - Access to many models, free tier available
# Get key: https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key

# HuggingFace - Inference API, free tier
# Get key: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_huggingface_api_key

# ============================================
# Embedding Providers (Optional - will fallback)
# ============================================

# Jina AI - 1M tokens free
# Get key: https://jina.ai
JINA_API_KEY=your_jina_api_key

# ============================================
# Google Drive Integration (Optional)
# ============================================

# Google Drive folder ID containing documents
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id

# Service account JSON (create at https://console.cloud.google.com)
# Download JSON key and paste contents here
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ============================================
# Application Settings
# ============================================

# Set default AI provider (groq, deepseek, openrouter, huggingface)
DEFAULT_AI_PROVIDER=groq

# Enable web search fallback
ENABLE_WEB_SEARCH=true

# Maximum chunks to retrieve per query
MAX_CHUNKS_PER_QUERY=5

# Similarity threshold (0-1)
SIMILARITY_THRESHOLD=0.7
